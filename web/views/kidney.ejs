<% layout("/layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-11">
      <div class="card disease-form-card shadow-lg border-0">
        <div class="card-header text-center">
          <h2 class="mb-0">
            <i class="fa-solid fa-kidneys me-2"></i>
            Kidney Disease Prediction
          </h2>
        </div>

        <div class="card-body p-4">
          <form action="/kidney" method="POST">
            <!-- Patient Information -->
            <h4 class="mb-3 text-success">Patient Information</h4>

            <div class="row">
              <div class="col-md-4 mb-3">
                <label class="form-label">Age</label>
                <input type="number" class="form-control" name="age" required />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Blood Pressure (mmHg) </label>
                <input type="number" class="form-control" name="bp" required />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Specific Gravity </label>

                <select class="form-select" name="sg" required>
                  <option value="">Select</option>
                  <option value="1.005">1.005</option>
                  <option value="1.010">1.010</option>
                  <option value="1.015">1.015</option>
                  <option value="1.020">1.020</option>
                  <option value="1.025">1.025</option>
                </select>
              </div>
            </div>

            <hr />

            <!-- Urine Analysis -->
            <h4 class="mb-3 text-success">Urine Analysis</h4>

            <div class="row">
              <div class="col-md-3 mb-3">
                <label class="form-label"> Albumin </label>

                <select class="form-select" name="al" required>
                  <option value="0">0</option>
                  <option value="1">1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                  <option value="4">4</option>
                  <option value="5">5</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Sugar </label>

                <select class="form-select" name="su" required>
                  <option value="0">0</option>
                  <option value="1">1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                  <option value="4">4</option>
                  <option value="5">5</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Red Blood Cells </label>

                <select class="form-select" name="rbc" required>
                  <option value="normal">Normal</option>
                  <option value="abnormal">Abnormal</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Pus Cell </label>

                <select class="form-select" name="pc" required>
                  <option value="normal">Normal</option>
                  <option value="abnormal">Abnormal</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Pus Cell Clumps </label>

                <select class="form-select" name="pcc" required>
                  <option value="notpresent">Not Present</option>
                  <option value="present">Present</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Bacteria </label>

                <select class="form-select" name="ba" required>
                  <option value="notpresent">Not Present</option>
                  <option value="present">Present</option>
                </select>
              </div>
            </div>

            <hr />

            <!-- Blood Tests -->
            <h4 class="mb-3 text-success">Blood Test Results</h4>

            <div class="row">
              <div class="col-md-4 mb-3">
                <label class="form-label"> Blood Glucose Random </label>
                <input type="number" class="form-control" name="bgr" required />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Blood Urea </label>
                <input type="number" class="form-control" name="bu" required />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Serum Creatinine </label>
                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="sc"
                  required
                />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Sodium </label>
                <input type="number" class="form-control" name="sod" required />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Potassium </label>
                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="pot"
                  required
                />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Hemoglobin </label>
                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="hemo"
                  required
                />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Packed Cell Volume </label>
                <input type="number" class="form-control" name="pcv" required />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> White Blood Cell Count </label>
                <input
                  type="number"
                  class="form-control"
                  name="wbcc"
                  required
                />
              </div>

              <div class="col-md-4 mb-3">
                <label class="form-label"> Red Blood Cell Count </label>
                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="rbcc"
                  required
                />
              </div>
            </div>

            <hr />

            <!-- Medical History -->
            <h4 class="mb-3 text-success">Medical History</h4>

            <div class="row">
              <div class="col-md-3 mb-3">
                <label class="form-label"> Hypertension </label>

                <select class="form-select" name="htn" required>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Diabetes </label>

                <select class="form-select" name="dm" required>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Coronary Artery Disease </label>

                <select class="form-select" name="cad" required>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Appetite </label>

                <select class="form-select" name="appet" required>
                  <option value="good">Good</option>
                  <option value="poor">Poor</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Pedal Edema </label>

                <select class="form-select" name="pe" required>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                </select>
              </div>

              <div class="col-md-3 mb-3">
                <label class="form-label"> Anemia </label>

                <select class="form-select" name="ane" required>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                </select>
              </div>
            </div>

            <button class="btn predict-btn w-100 mt-3">
              <i class="fa-solid fa-kidneys me-2"></i>
              Predict Kidney Disease Risk
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
