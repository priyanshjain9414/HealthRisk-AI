<% layout("/layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card disease-form-card shadow-lg border-0">
        <div class="card-header text-center">
          <h2 class="mb-0">
            <i class="fa-solid fa-droplet me-2"></i>
            Diabetes Prediction
          </h2>
        </div>

        <div class="card-body p-4">
          <form action="/diabetes" method="POST">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label"> Pregnancies </label>

                <input
                  type="number"
                  class="form-control"
                  name="Pregnancies"
                  min="0"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> Glucose </label>

                <input
                  type="number"
                  class="form-control"
                  name="Glucose"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> Skin Thickness </label>

                <input
                  type="number"
                  class="form-control"
                  name="SkinThickness"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> Insulin </label>

                <input
                  type="number"
                  class="form-control"
                  name="Insulin"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> BMI </label>

                <input
                  type="number"
                  step="0.01"
                  class="form-control"
                  name="BMI"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> Diabetes Pedigree Function </label>

                <input
                  type="number"
                  step="0.01"
                  class="form-control"
                  name="DiabetesPedigreeFunction"
                  required
                />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> Age </label>

                <input type="number" class="form-control" name="Age" required />
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label"> Blood Pressure </label>

                <input
                  type="number"
                  class="form-control"
                  name="BloodPressure"
                  required
                />
              </div>
            </div>

            <button class="btn predict-btn w-100">
              <i class="fa-solid fa-heart-pulse me-2"></i>
              Predict Risk
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
