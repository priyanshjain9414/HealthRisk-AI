<% layout("/layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card disease-form-card shadow-lg border-0">
        <div class="card-header text-center">
          <h2 class="mb-0">
            <i class="fa-solid fa-vial me-2"></i>
            Anemia Prediction
          </h2>
        </div>

        <div class="card-body p-4">
          <form action="/anemia" method="POST">
            <div class="row">
              <!-- Gender -->
              <div class="col-md-6 mb-3">
                <label class="form-label"> Gender </label>

                <select class="form-select" name="Gender" required>
                  <option value="">Select Gender</option>
                  <option value="1">Male</option>
                  <option value="0">Female</option>
                </select>
              </div>

              <!-- Hemoglobin -->
              <div class="col-md-6 mb-3">
                <label class="form-label"> Hemoglobin (g/dL) </label>

                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="Hemoglobin"
                  required
                />
              </div>

              <!-- MCH -->
              <div class="col-md-4 mb-3">
                <label class="form-label"> MCH </label>

                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="MCH"
                  required
                />

                <small class="text-muted"> Mean Corpuscular Hemoglobin </small>
              </div>

              <!-- MCHC -->
              <div class="col-md-4 mb-3">
                <label class="form-label"> MCHC </label>

                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="MCHC"
                  required
                />

                <small class="text-muted">
                  Mean Corpuscular Hemoglobin Concentration
                </small>
              </div>

              <!-- MCV -->
              <div class="col-md-4 mb-3">
                <label class="form-label"> MCV </label>

                <input
                  type="number"
                  step="0.1"
                  class="form-control"
                  name="MCV"
                  required
                />

                <small class="text-muted"> Mean Corpuscular Volume </small>
              </div>
            </div>

            <button class="btn predict-btn w-100 mt-3">
              <i class="fa-solid fa-vial me-2"></i>
              Predict Anemia Risk
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
